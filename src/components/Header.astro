---
// Header component for AI-Automation-Engineers.de
---

<header class="absolute top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-3 group">
          <div class="w-12 h-10 bg-gray-900 rounded-2xl flex items-center justify-center group-hover:bg-gray-800 transition-colors">
            <span class="text-white font-bold text-sm">AAE</span>
          </div>
          <span class="text-xl font-semibold text-gray-900 hidden sm:block">AI-Automation-Engineers.de</span>
        </a>

        <!-- Powered by workshops.de -->
        <div class="ml-6 pl-6 border-l border-gray-200 hidden lg:flex items-center">
          <a href="https://workshops.de?utm_source=ai-automation-engineers_de&utm_campaign=crossmarketing_permanent&utm_medium=portal&utm_content=header" target="_blank" class="flex items-center space-x-2 hover:opacity-80 transition-opacity">
            <img src="/logo-workshopsde-color400w.png" alt="workshops.de" class="w-8 h-8">
            <div class="flex flex-col">
              <span class="text-xs text-gray-500 leading-none">Powered by</span>
              <span class="text-sm font-semibold text-gray-700 leading-none">workshops.de</span>
            </div>
          </a>
        </div>

        <!-- Mobile powered by (logo only) -->
        <div class="ml-4 lg:hidden">
          <a href="https://workshops.de?utm_source=ai-automation-engineers_de&utm_campaign=crossmarketing_permanent&utm_medium=portal&utm_content=header" target="_blank" class="hover:opacity-80 transition-opacity">
            <img src="/logo-workshopsde-color400w.png" alt="workshops.de" class="w-6 h-6">
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="hidden md:flex items-center space-x-6">
        <a href="/news" class="text-gray-600 hover:text-gray-900 transition-colors font-medium">
          AI-News
        </a>
        <a href="/community" class="text-gray-600 hover:text-gray-900 transition-colors font-medium">
          Community
        </a>
        <!-- Auth Button -->
        <div id="header-auth-container" class="flex items-center">
          <!-- Auth button will be mounted here -->
          <button id="temp-auth-btn" class="bg-orange-500 hover:bg-orange-600 text-white font-medium px-4 py-2 rounded-lg transition-colors text-sm">
            Sign In
          </button>
        </div>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-button" class="md:hidden p-3 rounded-full hover:bg-gray-100 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="md:hidden border-t border-gray-200 py-6 hidden">
      <nav class="flex flex-col space-y-6">
        <a href="/" class="text-gray-700 hover:text-gray-900 transition-colors font-medium text-lg">Home</a>
        <a href="/news" class="text-gray-700 hover:text-gray-900 transition-colors font-medium text-lg">News</a>
        <a href="/community" class="text-gray-700 hover:text-gray-900 transition-colors font-medium text-lg">Community</a>
        <!-- Mobile Auth -->
        <div id="mobile-auth-container" class="pt-4 border-t border-gray-200">
          <button id="temp-mobile-auth-btn" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold px-4 py-3 rounded-lg transition-colors">
            Sign In with Google
          </button>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', function() {
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    if (menuButton && mobileMenu) {
      menuButton.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
      });
    }

    // Mount auth buttons
    mountAuthButtons();
  });

  async function mountAuthButtons() {
    try {
      // Import Firebase auth functions
      const { auth } = await import('../lib/firebase');
      const { onAuthStateChanged, signInWithPopup, GoogleAuthProvider, signOut } = await import('firebase/auth');
      
      // Google Auth Provider
      const googleProvider = new GoogleAuthProvider();
      googleProvider.setCustomParameters({
        prompt: 'select_account'
      });

      let currentUser = null;

      // Auth state listener
      onAuthStateChanged(auth, (user) => {
        currentUser = user;
        updateAuthButtons(user);
        console.log('Auth state changed:', user ? 'logged in' : 'logged out');
      });

      // Sign in function
      async function handleSignIn() {
        try {
          console.log('Starting sign in...');
          const result = await signInWithPopup(auth, googleProvider);
          console.log('Sign in successful:', result.user);
        } catch (error) {
          console.error('Sign in failed:', error);
          alert(`Sign in failed: ${error.message}`);
        }
      }

      // Sign out function
      async function handleSignOut() {
        try {
          await signOut(auth);
          console.log('Sign out successful');
        } catch (error) {
          console.error('Sign out failed:', error);
        }
      }

      // Update button states
      function updateAuthButtons(user) {
        const tempHeaderBtn = document.getElementById('temp-auth-btn');
        const tempMobileBtn = document.getElementById('temp-mobile-auth-btn');

        if (user) {
          // User is logged in - show user info and sign out
          const userInitials = user.displayName?.split(' ').map(n => n[0]).join('') || 'U';
          
          if (tempHeaderBtn) {
            tempHeaderBtn.textContent = userInitials;
            tempHeaderBtn.onclick = handleSignOut;
            tempHeaderBtn.className = 'bg-green-500 hover:bg-green-600 text-white font-medium px-3 py-2 rounded-full transition-colors text-sm';
          }
          
          if (tempMobileBtn) {
            tempMobileBtn.textContent = `Sign Out (${user.displayName || user.email?.split('@')[0]})`;
            tempMobileBtn.onclick = handleSignOut;
            tempMobileBtn.className = 'w-full bg-green-500 hover:bg-green-600 text-white font-semibold px-4 py-3 rounded-lg transition-colors';
          }
        } else {
          // User is not logged in - show sign in button
          if (tempHeaderBtn) {
            tempHeaderBtn.textContent = 'Sign In';
            tempHeaderBtn.onclick = handleSignIn;
            tempHeaderBtn.className = 'bg-orange-500 hover:bg-orange-600 text-white font-medium px-4 py-2 rounded-lg transition-colors text-sm';
          }
          
          if (tempMobileBtn) {
            tempMobileBtn.textContent = 'Sign In with Google';
            tempMobileBtn.onclick = handleSignIn;
            tempMobileBtn.className = 'w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold px-4 py-3 rounded-lg transition-colors';
          }
        }
      }

      // Initial setup for temporary buttons
      const tempHeaderBtn = document.getElementById('temp-auth-btn');
      const tempMobileBtn = document.getElementById('temp-mobile-auth-btn');
      
      if (tempHeaderBtn) tempHeaderBtn.onclick = handleSignIn;
      if (tempMobileBtn) tempMobileBtn.onclick = handleSignIn;

    } catch (error) {
      console.error('Error mounting auth buttons:', error);
    }
  }
</script>

<style>
  /* Custom styles for header */
  .text-blue-600 {
    color: #3b82f6;
  }

  .bg-blue-600 {
    background-color: #3b82f6;
  }

  .hover\:bg-blue-700:hover {
    background-color: #1d4ed8;
  }

  .hover\:text-blue-600:hover {
    color: #3b82f6;
  }
</style>