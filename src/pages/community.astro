---
import BaseLayout from '../layouts/BaseLayout.astro';
import videosData from '../data/videos.json';

const title = 'Mitreisen';
const description = 'Begleite Robin Böhm auf seiner KI-Reise — exklusive Einblicke, Live-Sessions und Premium-Inhalte direkt aus der AI-Entwicklung.';

const previewVideos = videosData.slice(0, 3);
---

<BaseLayout {title} {description}>
  <!-- Hero Section -->
  <section class="relative min-h-[80vh] bg-gradient-to-br from-gray-900 via-gray-800 to-black overflow-hidden">
    <!-- Background Animation -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-grid-white/10 [mask-image:linear-gradient(0deg,black,rgba(0,0,0,0.4))]"></div>
      <div class="absolute top-1/4 left-1/4 w-72 h-72 bg-orange-500/20 rounded-full mix-blend-multiply filter blur-xl animate-blob"></div>
      <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-blue-500/20 rounded-full mix-blend-multiply filter blur-xl animate-blob animation-delay-2000"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-20">
      <div class="text-center">
        <!-- Main Headline -->
        <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold tracking-tight mb-8 leading-none">
          <span class="block text-white">Auf der</span>
          <span class="block bg-gradient-to-r from-orange-400 to-blue-400 bg-clip-text text-transparent">KI-Reise</span>
        </h1>
        
        <!-- Subtitle -->
        <p class="text-xl sm:text-2xl text-gray-300 mb-12 max-w-3xl mx-auto font-light leading-relaxed">
          Begleite mich auf der Expedition durch die KI-Welt —<br>
          exklusive Berichte, Live-Sessions und Entdeckungen
        </p>

        <!-- Auth Section -->
        <div class="max-w-md mx-auto">
          <div id="auth-section">
            <div class="bg-white/10 backdrop-blur-sm rounded-lg p-6 border border-white/20">
              <p class="text-white mb-4">Reise mit mir durch die KI-Welt</p>
              <button onclick="showAuthModal()" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-4 rounded-lg transition-colors">
                Mitreisen starten
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Preview Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
        <div>
          <h2 class="text-4xl font-bold text-gray-900 mb-3">Exklusive Reise-Einblicke</h2>
          <p class="text-xl text-gray-600 max-w-2xl">
            Begleite mich bei Live-Sessions, Tool-Tests und Deep-Dives — ungefilterte Einblicke in die KI-Entwicklung
          </p>
        </div>
        <a
          href="/community/videos"
          class="shrink-0 inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm"
        >
          Alle Videos ansehen
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Video Grid -->
      <div id="video-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {previewVideos.map(video => (
          <article class="video-card group relative bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300">
            <a href={`/community/videos/${video.slug}`} class="block relative aspect-video bg-gray-900 overflow-hidden">
              <img
                src={`https://img.youtube.com/vi/${video.youtubeId}/hqdefault.jpg`}
                alt={video.title}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors"></div>
              <!-- Play button -->
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-16 h-16 bg-white/90 rounded-full flex items-center justify-center transition-all group-hover:bg-white group-hover:scale-110 shadow-lg">
                  <svg class="w-6 h-6 text-gray-900 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <!-- Lock overlay (hidden when authenticated) -->
              <div class="auth-lock-overlay absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="bg-white rounded-xl p-4 text-center shadow-lg">
                  <svg class="w-8 h-8 text-gray-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                  </svg>
                  <p class="text-sm font-semibold text-gray-900 mb-1">Login erforderlich</p>
                  <p class="text-xs text-gray-500">Kostenlos anmelden</p>
                </div>
              </div>
            </a>
            <div class="p-6">
              <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-orange-600 transition-colors line-clamp-2">{video.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-2">{video.description}</p>
              <a href={`/community/videos/${video.slug}`} class="inline-flex items-center text-sm font-medium text-orange-600 hover:text-orange-800 transition-colors">
                Details ansehen
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- CTA to full overview -->
      <div class="text-center mt-12">
        <a
          href="/community/videos"
          class="inline-flex items-center gap-2 border-2 border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white font-semibold px-8 py-3 rounded-xl transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          Alle Lernvideos durchsuchen
        </a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Was erwartet dich auf der Reise?</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Live-Berichte</h3>
          <p class="text-gray-600">
            Ich teile direkt was ich gerade lerne — neue Tools, Workflows und Erkenntnisse aus der KI-Praxis
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Gemeinsame Entdeckungen</h3>
          <p class="text-gray-600">
            Live-Sessions wo wir gemeinsam neue Tools erkunden und Erfahrungen austauschen
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Insider-Perspektiven</h3>
          <p class="text-gray-600">
            Ungefilterte Einblicke und ehrliche Bewertungen — was ich wirklich von neuen KI-Tools halte
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Auth Modal -->
<div id="auth-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden">
  <div class="relative bg-white rounded-2xl p-8 max-w-md w-full text-center shadow-2xl">
    <button class="close-modal absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
      </svg>
    </div>
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Mit Google anmelden</h2>
    <p class="text-gray-600 mb-6">
      Melde dich kostenlos mit deinem Google-Account an, um Zugang zu allen Community-Videos zu erhalten.
    </p>
    <div id="auth-button-container"></div>
    <p class="text-sm text-gray-500 mt-4">Kostenlose Anmeldung · Kein Passwort nötig</p>
  </div>
</div>

<script>
  import { onAuthStateChanged } from 'firebase/auth';
  import { auth } from '../lib/firebase';
  import { createRoot } from 'react-dom/client';
  import React from 'react';
  import AuthButtonStandalone from '../components/AuthButtonStandalone';

  let isAuthenticated = false;

  function showAuthModal() {
    document.getElementById('auth-modal')?.classList.remove('hidden');
  }

  function hideAuthModal() {
    document.getElementById('auth-modal')?.classList.add('hidden');
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Mount Google auth button in modal
    const container = document.getElementById('auth-button-container');
    if (container) {
      const root = createRoot(container);
      root.render(React.createElement(AuthButtonStandalone, {
        className: 'w-full justify-center text-lg px-8 py-4'
      }));
    }

    // Close modal on button click
    document.querySelectorAll('.close-modal').forEach(btn => {
      btn.addEventListener('click', hideAuthModal);
    });

    // Close modal on backdrop click
    document.getElementById('auth-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) hideAuthModal();
    });

    // Intercept video card clicks: show auth modal when not logged in
    document.querySelectorAll('.video-card a').forEach(link => {
      link.addEventListener('click', (e) => {
        if (!isAuthenticated) {
          e.preventDefault();
          showAuthModal();
        }
      });
    });

    // Auth state
    onAuthStateChanged(auth, (user) => {
      isAuthenticated = !!user;

      if (user) {
        hideAuthModal();
        document.getElementById('auth-section')?.classList.add('hidden');
        // Remove lock overlays from video cards
        document.querySelectorAll('.auth-lock-overlay').forEach(el => el.remove());
      } else {
        document.getElementById('auth-section')?.classList.remove('hidden');
      }
    });
  });

  (window as unknown as Record<string, unknown>).showAuthModal = showAuthModal;
  (window as unknown as Record<string, unknown>).hideAuthModal = hideAuthModal;
</script>

<style>
  /* Custom animations */
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  
  .animate-blob {
    animation: blob 7s infinite;
  }
  
  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .bg-grid-white\/10 {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(255 255 255 / 0.1)'%3e%3cpath d='m0 .5 32 0M.5 0 .5 32'/%3e%3c/svg%3e");
  }

  /* Auth state management */
  .auth-required {
    display: block;
  }

  .authenticated .auth-required {
    display: none;
  }

  .authenticated .video-play-btn,
  .authenticated .video-watch-btn {
    opacity: 1;
    cursor: pointer;
  }

  .auth-overlay {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .unauthenticated .auth-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  /* Set initial state as unauthenticated */
  body {
    &.unauthenticated .video-play-btn,
    &.unauthenticated .video-watch-btn {
      opacity: 0.6;
      cursor: not-allowed;
    }
  }
</style>
</BaseLayout>