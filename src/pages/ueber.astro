---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Über dieses Projekt';
const description = 'AI-Automation-Engineers.de ist ein Experiment: Ein Web-Portal, das seit 2025 vollständig von KI-Agents entwickelt und betrieben wird – kein einziger Zeile Code von einem Menschen.';
---

<BaseLayout {title} {description}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-white pt-32 pb-20">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-50 via-white to-blue-50">
      <div class="absolute top-1/3 right-1/3 w-96 h-96 bg-blue-100 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"></div>
      <div class="absolute bottom-1/4 left-1/4 w-72 h-72 bg-gray-100 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob animation-delay-2000"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-6">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-600">
          Seit 2025 · Side-Projekt
        </span>
      </div>
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-gray-900 mb-6">
        Über dieses<br>
        <span class="bg-gradient-to-r from-gray-700 to-gray-400 bg-clip-text text-transparent">Experiment.</span>
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
        Ein Web-Portal, das vollständig von KI-Agents entwickelt und betrieben wird.
        Kein einziger Zeile Code wurde von einem Menschen geschrieben.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">

        <!-- Left: Main story -->
        <div class="lg:col-span-2 space-y-12">

          <!-- Origin -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Die Idee</h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              AI-Automation-Engineers.de wurde 2025 von <strong class="text-gray-900">Robin Böhm</strong> als Side- und Testprojekt gestartet –
              mit einer einfachen Frage: Kann ein Web-Portal komplett von KI-Agents entwickelt und betrieben werden?
            </p>
            <p class="text-gray-600 leading-relaxed">
              Die Antwort ist dieses Portal. Keine einzige Zeile Code wurde von einem Menschen geschrieben.
              Robin kuratiert die Richtung und die Quellen – den Rest übernehmen die Agents.
            </p>
          </div>

          <!-- Content Pipeline -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Die Content-Pipeline</h2>
            <p class="text-gray-600 leading-relaxed mb-6">
              Hinter dem Portal steckt eine vollautomatische Content-Pipeline:
              Ein Agent hat ein eigenes Postfach und Social-Media-Accounts, durchsucht kontinuierlich
              diverse Quellen nach relevanten News rund um KI-Automatisierung und schreibt eigenständig
              Artikel dazu – kuratiert, aber nicht verfasst von Robin.
            </p>
            <div class="bg-gray-50 rounded-2xl p-6 space-y-3">
              {[
                { icon: '📬', step: 'Quellen', desc: 'Agent-Postfach und Social-Media-Accounts sammeln News aus verschiedenen Kanälen' },
                { icon: '🔍', step: 'Selektion', desc: 'Der Agent bewertet und filtert relevante Inhalte für die Community' },
                { icon: '✍️', step: 'Erstellung', desc: 'Artikel werden vollständig vom Agent verfasst und aufbereitet' },
                { icon: '🚀', step: 'Veröffentlichung', desc: 'Automatische Publikation über die CI/CD-Pipeline auf GitHub Actions' },
              ].map(item => (
                <div class="flex items-start gap-4">
                  <div class="text-2xl flex-shrink-0 mt-0.5">{item.icon}</div>
                  <div>
                    <div class="font-semibold text-gray-900 text-sm">{item.step}</div>
                    <div class="text-gray-500 text-sm">{item.desc}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Tech Stack -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Technologie-Stack</h2>
            <p class="text-gray-500 text-sm mb-6">
              Das Portal befindet sich im steten Wandel – neue Technologien werden laufend getestet und evaluiert.
            </p>

            <div class="space-y-3">
              {[
                {
                  name: 'n8n',
                  desc: 'Workflow-Automatisierung und KI-Agenten-Orchestrierung für die Content-Pipeline',
                  color: 'bg-orange-100 text-orange-700'
                },
                {
                  name: 'Cursor',
                  desc: 'KI-gestütztes IDE für die vollautomatische Entwicklung des Portals selbst',
                  color: 'bg-violet-100 text-violet-700'
                },
                {
                  name: 'Claude Code',
                  desc: 'Agentic Software Engineering – schreibt, refactored und testet den Code autonom',
                  color: 'bg-blue-100 text-blue-700'
                },
                {
                  name: 'GitHub Actions + Claude Code',
                  desc: 'CI/CD-Pipeline mit integrierten Claude-Code-Agents für automatisierte Deployments',
                  color: 'bg-gray-100 text-gray-700'
                },
                {
                  name: 'LangChain',
                  desc: 'Eigene Implementierung für spezifische Agent-Workflows und Retrieval-Pipelines',
                  color: 'bg-green-100 text-green-700'
                },
              ].map(tech => (
                <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-100 hover:border-gray-200 transition-colors">
                  <span class={`inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-bold flex-shrink-0 ${tech.color}`}>
                    {tech.name}
                  </span>
                  <p class="text-gray-600 text-sm leading-relaxed">{tech.desc}</p>
                </div>
              ))}
            </div>

            <div class="mt-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
              <p class="text-sm text-blue-700">
                <strong>Evaluation als Prinzip:</strong> Dieselben Prozesse werden bewusst in verschiedenen Umgebungen
                umgesetzt, um Vor- und Nachteile der jeweiligen Ansätze direkt vergleichen zu können.
              </p>
            </div>
          </div>

        </div>

        <!-- Right: Sidebar -->
        <div class="space-y-6">

          <!-- Robin -->
          <div class="bg-gray-50 rounded-2xl p-6">
            <h3 class="font-semibold text-gray-900 mb-4 text-sm uppercase tracking-wider">Initiator</h3>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center text-white font-bold">
                RB
              </div>
              <div>
                <div class="font-semibold text-gray-900">Robin Böhm</div>
                <div class="text-sm text-gray-500">CEO, workshops.de</div>
              </div>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed">
              Robin kuratiert die inhaltliche Richtung des Projekts – alle anderen Aufgaben übernehmen die Agents.
            </p>
          </div>

          <!-- Facts -->
          <div class="bg-gray-50 rounded-2xl p-6">
            <h3 class="font-semibold text-gray-900 mb-4 text-sm uppercase tracking-wider">Fakten</h3>
            <ul class="space-y-3 text-sm">
              {[
                { label: 'Gestartet', value: '2025' },
                { label: 'Code von Menschen', value: '0 Zeilen' },
                { label: 'Artikel von Menschen', value: '0 Artikel' },
                { label: 'Typ', value: 'Side-Projekt' },
                { label: 'Framework', value: 'Astro + Tailwind' },
              ].map(fact => (
                <li class="flex justify-between items-center">
                  <span class="text-gray-500">{fact.label}</span>
                  <span class="font-medium text-gray-900">{fact.value}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Powered by -->
          <div class="bg-gray-900 rounded-2xl p-6 text-white">
            <h3 class="font-semibold mb-3 text-sm uppercase tracking-wider text-gray-400">Powered by</h3>
            <a href="https://workshops.de?utm_source=ai-automation-engineers_de&utm_campaign=crossmarketing_permanent&utm_medium=portal&utm_content=ueber-page"
               target="_blank"
               class="flex items-center gap-3 hover:opacity-80 transition-opacity">
              <img src="/logo-workshopsde-color400w.png" alt="workshops.de" class="w-8 h-8">
              <div>
                <div class="font-semibold">workshops.de</div>
                <div class="text-xs text-gray-400">KI-Schulungen & Training</div>
              </div>
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 bg-gray-50 border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-500 mb-6 max-w-xl mx-auto">
        Interessiert an KI-Automatisierung und Agentic Engineering?
        Lerne die Technologien hinter diesem Projekt in unseren Schulungen kennen.
      </p>
      <a href="/lernpfade"
         class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-gray-900 rounded-full hover:bg-gray-800 transition-all duration-300 shadow-sm">
        Zu den Lernpfaden
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
