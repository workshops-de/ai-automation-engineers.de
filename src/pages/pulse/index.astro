---
import BaseLayout from '../../layouts/BaseLayout.astro';
import pulseEpisodes from '../../data/pulse.json';

const title = 'AI Automation Pulse';
const description = 'Der AI Automation Pulse – ein News-Thema pro Folge, das gerade wirklich relevant ist. Kurz, direkt, mit meiner persönlichen Einschätzung. Kein fixer Rhythmus — erscheint wenn es Sinn macht.';

const episodes = [...pulseEpisodes].sort((a, b) => b.number - a.number);
---

<BaseLayout {title} {description}>
  <!-- Hero Section -->
  <section class="relative min-h-[55vh] bg-white overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-gray-50 via-white to-orange-50">
      <div class="absolute inset-0 bg-grid-slate-100 [mask-image:linear-gradient(0deg,white,rgba(255,255,255,0.6))]"></div>
      <div class="absolute top-1/4 left-1/5 w-56 h-56 bg-orange-100 rounded-full mix-blend-multiply filter blur-xl opacity-40 animate-blob"></div>
      <div class="absolute top-1/3 right-1/4 w-48 h-48 bg-red-100 rounded-full mix-blend-multiply filter blur-xl opacity-40 animate-blob animation-delay-2000"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20">
      <div class="text-center">
        <!-- Label -->
        <div class="inline-flex items-center gap-2 bg-orange-100 text-orange-700 text-sm font-semibold px-4 py-2 rounded-full mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-500 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
          </span>
          Kein fester Rhythmus — kommt wenn's was gibt
        </div>

        <!-- Headline -->
        <h1 class="text-6xl sm:text-7xl lg:text-8xl font-bold tracking-tight mb-8 leading-none">
          <span class="block text-gray-900">AI Automation</span>
          <span class="block bg-gradient-to-r from-orange-500 to-red-500 bg-clip-text text-transparent">Pulse.</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-xl sm:text-2xl text-gray-600 mb-6 max-w-3xl mx-auto font-light leading-relaxed">
          Ein Thema pro Folge — das gerade wirklich relevant ist.<br>
          Kurz erklärt, mit meiner Einschätzung dazu.
        </p>
        <p class="text-base text-gray-500 max-w-xl mx-auto">
          Kein Weekly, kein Pflicht-Update. Ich poste wenn ein Tool, ein Release oder eine News es wirklich wert ist.
        </p>
      </div>
    </div>
  </section>

  <!-- Format Info -->
  <section class="py-12 bg-gray-50 border-y border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 bg-orange-100 rounded-2xl flex items-center justify-center">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900">YouTube-Video</h3>
          <p class="text-sm text-gray-500">Kurz und auf den Punkt — kein Padding, keine Füllsätze</p>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 bg-blue-100 rounded-2xl flex items-center justify-center">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900">Begleitartikel</h3>
          <p class="text-sm text-gray-500">Das Thema nochmal als Text — mit allen Links und Quellen</p>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 bg-green-100 rounded-2xl flex items-center justify-center">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900">1 Thema pro Folge</h3>
          <p class="text-sm text-gray-500">Ein News-Thema, das es wirklich wert ist — mit meiner Meinung dazu</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Episodes List -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      {episodes.length === 0 ? (
        <!-- Empty State -->
        <div class="text-center py-24">
          <div class="w-20 h-20 bg-orange-100 rounded-3xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">Der erste Pulse kommt bald.</h2>
          <p class="text-gray-500 max-w-md mx-auto">Sobald genug relevante News zusammengekommen sind oder ein großes Event es rechtfertigt, erscheint Pulse #1.</p>
        </div>
      ) : (
        <div class="space-y-16">
          {episodes.map((episode) => (
            <article class="group">
              <!-- Episode Header -->
              <div class="flex items-start gap-6 mb-8">
                <a href={`/pulse/${episode.slug}`} class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-orange-500 to-red-500 rounded-2xl flex items-center justify-center shadow-lg hover:scale-105 transition-transform">
                  <span class="text-white font-bold text-lg">#{episode.number}</span>
                </a>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <span class="text-sm font-medium text-orange-600 bg-orange-50 px-3 py-1 rounded-full">
                      Pulse #{episode.number}
                    </span>
                    <span class="text-sm text-gray-400">
                      {new Date(episode.publishedAt).toLocaleDateString('de-DE', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </span>
                  </div>
                  <a href={`/pulse/${episode.slug}`} class="group/title">
                    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 group-hover/title:text-orange-600 transition-colors leading-tight mb-3">
                      {episode.title}
                    </h2>
                  </a>
                  <p class="text-gray-600 text-lg leading-relaxed">
                    {episode.description}
                  </p>

                  <!-- Topics -->
                  {episode.topics && episode.topics.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {episode.topics.map((topic: string) => (
                        <span class="text-xs text-gray-500 bg-gray-100 px-3 py-1 rounded-full">
                          {topic}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>

              <!-- YouTube Embed -->
              {episode.youtubeId ? (
                <div class="rounded-2xl overflow-hidden shadow-lg bg-black aspect-video mb-6">
                  <iframe
                    src={`https://www.youtube.com/embed/${episode.youtubeId}`}
                    title={episode.title}
                    class="w-full h-full"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>
              ) : (
                <div class="rounded-2xl bg-gray-50 border-2 border-dashed border-gray-200 aspect-video flex items-center justify-center mb-6">
                  <div class="text-center">
                    <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                    </svg>
                    <p class="text-gray-400 text-sm">Video erscheint in Kürze</p>
                  </div>
                </div>
              )}

              <!-- Links -->
              <div class="flex flex-wrap items-center gap-4 mt-2">
                <a
                  href={`/pulse/${episode.slug}`}
                  class="inline-flex items-center gap-2 text-orange-600 hover:text-orange-700 font-semibold transition-colors group/link"
                >
                  Details, Quellen & mehr
                  <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
                {episode.articleUrl && (
                  <a
                    href={episode.articleUrl}
                    class="inline-flex items-center gap-2 text-gray-500 hover:text-gray-800 text-sm font-medium transition-colors group/article"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    Zum Artikel
                  </a>
                )}
              </div>

              <!-- Divider -->
              <div class="mt-12 border-b border-gray-100"></div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-6">
        Keinen Pulse verpassen.
      </h2>
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
        Abonniere den YouTube-Kanal — dort erfährst du als erstes, wenn ein neuer Pulse erscheint.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://www.youtube.com/@AIAutomationEngineers"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 bg-red-600 hover:bg-red-700 text-white font-semibold px-8 py-4 rounded-full transition-all duration-300 shadow-lg hover:shadow-xl"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          YouTube abonnieren
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
